{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/CopilotNexus.slnx",
                "--no-incremental"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "run",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/CopilotNexus.App/CopilotNexus.App.csproj"
            ],
            "dependsOn": "build",
            "problemMatcher": []
        },
        {
            "label": "run (test mode)",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/CopilotNexus.App/CopilotNexus.App.csproj",
                "--",
                "--test-mode"
            ],
            "dependsOn": "build",
            "problemMatcher": []
        },
        {
            "label": "test: all",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/CopilotNexus.slnx",
                "--verbosity",
                "normal"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test: core",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/test/CopilotNexus.Core.Tests/CopilotNexus.Core.Tests.csproj",
                "--verbosity",
                "normal"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test: app",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/test/CopilotNexus.App.Tests/CopilotNexus.App.Tests.csproj",
                "--verbosity",
                "normal"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test: ui",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/test/CopilotNexus.UI.Tests/CopilotNexus.UI.Tests.csproj",
                "--verbosity",
                "normal"
            ],
            "dependsOn": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish-dist",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/CopilotNexus.App/CopilotNexus.App.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/dist",
                "--self-contained",
                "false"
            ],
            "dependsOn": "build",
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "stage-update",
            "command": "dotnet",
            "presentation": {
                "showReuseMessage": false,
                "reveal": "silent",
                "close": true
            },
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/CopilotNexus.App/CopilotNexus.App.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/dist/staging",
                "--self-contained",
                "false"
            ],
            "dependsOn": "build",
            "problemMatcher": "$msCompile",
            "group": "build"
        }
    ]
}