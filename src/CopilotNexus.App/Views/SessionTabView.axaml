<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CopilotNexus.App.Converters"
             x:Class="CopilotNexus.App.Views.SessionTabView"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:MessageRoleToBrushConverter x:Key="RoleToBrushConverter"/>
        <converters:MessageRoleToLabelConverter x:Key="RoleToLabelConverter"/>
        <converters:NullToCollapsedConverter x:Key="NullToVisible"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Session status bar -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="8,4"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Clear"
                            Command="{Binding ClearCommand}"
                            Name="ClearButton"
                            Margin="4,0"
                            Padding="8,2"
                            Background="Transparent"
                            Foreground="{StaticResource ForegroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"/>
                    <Button Content="Abort"
                            Command="{Binding AbortCommand}"
                            Name="AbortButton"
                            Margin="4,0"
                            Padding="8,2"
                            Background="Transparent"
                            Foreground="#F44747"
                            BorderBrush="{StaticResource BorderBrush}"
                            ToolTip.Tip="Cancel current request"/>
                </StackPanel>
                <TextBlock Text="{Binding Title}"
                           Foreground="{StaticResource ForegroundBrush}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <!-- Messages area (fills remaining space, scrolls internally) -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Messages}"
                 Name="MessagesList"
                 Background="{StaticResource BackgroundBrush}"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,6"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,0.5">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy"
                                          Click="CopyMessageMenuItem_Click"
                                          Tag="{Binding}"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding Role, Converter={StaticResource RoleToLabelConverter}}"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           Foreground="{Binding Role, Converter={StaticResource RoleToBrushConverter}}"
                                           Margin="0,0,8,2"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                           FontSize="10"
                                           Foreground="{StaticResource SystemMessageBrush}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock/>
                            </DockPanel>
                            <TextBlock Text="{Binding Content}"
                                       Foreground="{Binding Role, Converter={StaticResource RoleToBrushConverter}}"
                                       TextWrapping="Wrap"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input area pinned to bottom -->
        <Border Grid.Row="2"
                Name="InputContainer"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding InputText}"
                         Name="InputTextBox"
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource ForegroundBrush}"
                         CaretBrush="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="13"
                         Padding="8,6"
                         VerticalContentAlignment="Center"
                         KeyDown="InputTextBox_KeyDown"/>
                <Button Grid.Column="1"
                        Content="Send"
                        Command="{Binding SendCommand}"
                        Name="SendButton"
                        Margin="8,0,0,0"
                        Padding="16,6"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Session context footer -->
        <Border Grid.Row="3"
                Name="SessionContextBar"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Path:"
                               Foreground="{StaticResource SystemMessageBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding WorkingDirectoryDisplay}"
                               Foreground="{StaticResource ForegroundBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="700"/>
                    <TextBlock Text="{Binding GitBranchDisplay, StringFormat='(branch: {0})'}"
                               Foreground="{StaticResource RunningIndicatorBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding GitBranchDisplay, Converter={StaticResource NullToVisible}}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Mode:"
                               Foreground="{StaticResource SystemMessageBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableModes}"
                              SelectedItem="{Binding SelectedMode}"
                              Name="ModeSelector"
                              MinWidth="120"
                              Height="26"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource ForegroundBrush}"
                              BorderBrush="{StaticResource BorderBrush}"/>

                    <TextBlock Text="Model:"
                               Foreground="{StaticResource SystemMessageBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel}"
                              Name="FooterModelSelector"
                              MinWidth="220"
                              MaxWidth="340"
                              Height="26"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource ForegroundBrush}"
                              BorderBrush="{StaticResource BorderBrush}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Reasoning:"
                               Foreground="{StaticResource SystemMessageBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ReasoningLevelDisplay}"
                               Foreground="{StaticResource ForegroundBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ModelCostDisplay, StringFormat='Cost: {0}'}"
                               Foreground="{StaticResource SystemMessageBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ModelCostDisplay, Converter={StaticResource NullToVisible}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
